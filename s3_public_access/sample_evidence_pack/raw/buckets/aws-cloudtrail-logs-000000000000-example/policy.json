{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AWSCloudTrailAclCheck20150319-4b0335b3-7aaf-497a-b1d7-0788213b9fd7",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::aws-cloudtrail-logs-000000000000-example",
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": "arn:aws:cloudtrail:us-east-2:000000000000:trail/jferg-management-trail"
        }
      }
    },
    {
      "Sid": "AWSCloudTrailWrite20150319-b9034c98-95b9-4201-8e97-2534de4d08a7",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::aws-cloudtrail-logs-000000000000-example/AWSLogs/000000000000/*",
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control",
          "AWS:SourceArn": "arn:aws:cloudtrail:us-east-2:000000000000:trail/jferg-management-trail"
        }
      }
    }
  ]
}